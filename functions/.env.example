# Primary path: Slack Incoming Webhook (free tier; good fit for later Block Kit + threads).
# Create: Slack App → Incoming Webhooks → activate → pick channel → copy Webhook URL.
# Style "slack" sends JSON { "text": "..." } — required for Slack incoming webhooks.
#
# NOTIFY_WEBHOOK_STYLE:
#   slack    — default; JSON { "text": "..." }
#   discord  — JSON { "content": "..." }
#   generic  — JSON { "message", "text" }
#
# Two-way workflows (buttons → your API → Firestore → notify DJ) are NOT handled by
# incoming webhooks alone; you will add a Slack app Interactivity Request URL later.
#
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_URL_2=
NOTIFY_WEBHOOK_STYLE=slack
